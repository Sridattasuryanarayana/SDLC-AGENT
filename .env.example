# SDLC Agent Configuration
# Copy this file to .env and fill in your values

# LLM Provider: mock | openai | anthropic | waip | local
LLM_PROVIDER=mock

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Anthropic Configuration  
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# WAIP Configuration
WAIP_API_KEY=your_waip_token_here
WAIP_API_ENDPOINT=https://api.waip.wiprocms.com
WAIP_MODEL=gpt-4o

# Local LLM (Ollama)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=codellama

# GitHub Configuration (for PR creation)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=Sridattasuryanarayana/SDLC-AGENT

# Settings
OUTPUT_DIR=./output
DEBUG_MODE=false
MAX_ITERATIONS=10
