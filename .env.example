# Multi-Agent Development Team Configuration
# SDLC Agentic Workflow

# ===========================================
# LLM Configuration
# ===========================================

# Choose your LLM provider: openai, anthropic, waip, local, or mock
LLM_PROVIDER=waip

# WAIP (Wipro AI Platform) Configuration
WAIP_API_KEY=your-waip-api-key-here
WAIP_API_ENDPOINT=https://api.waip.wiprocms.com
WAIP_MODEL=gpt-4o

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Anthropic Configuration (alternative)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local LLM Configuration (for zero-cost option)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=codellama

# ===========================================
# SDLC Workflow Settings
# ===========================================

# Task tracking file (Excel or JSON)
TASKS_FILE=tasks/development_tasks.xlsx

# Output directory for generated code
OUTPUT_DIR=./output

# Workflow settings
AUTO_CREATE_PR=true
POLL_INTERVAL=10
PR_CHECK_INTERVAL=30
MAX_ITERATIONS=10
DEBUG_MODE=false

# ===========================================
# Git Configuration
# ===========================================

# Repository settings
GIT_REPO_URL=https://github.com/your-org/your-repo.git
GIT_LOCAL_PATH=./workspace
GIT_MAIN_BRANCH=main

# ===========================================
# GitHub Configuration (for PR creation)
# ===========================================

# Get token from: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-token-here
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name
